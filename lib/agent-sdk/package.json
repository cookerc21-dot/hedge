{
  "name": "@injective/agent-sdk",
  "version": "0.2.1",
  "description": "TypeScript SDK for managing agent identities on the Injective chain",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/browser.js",
        "types": "./dist/browser.d.ts"
      },
